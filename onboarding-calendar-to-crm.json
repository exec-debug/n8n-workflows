    {
      "parameters": {
        "jsCode": "// Safely pull context from whichever tracker branch ran\nlet r = null;\ntry { r = $('Set Tracker Id (Update)').item.json; } catch(e) {}\nif (!r || !r.subject) {\n  try { r = $('Set Tracker Id (Create)').item.json; } catch(e) {}\n}\nif (!r || !r.subject) { r = $input.first().json; }\n\nconst desc = [\n  'SOURCE: Example User Calendar (Outlook / user@example.com)',\n  'ORGANIZER: ' + (r.organizer || 'unknown'),\n  'ALL ATTENDEES: ' + (r.allAttendees || 'none'),\n  'EXTERNAL ATTENDEES: ' + (r.externalAttendees || 'none'),\n  'PRIMARY EMAIL: ' + (r.primaryEmail || 'none'),\n  'DOMAIN: ' + (r.primaryDomain || 'unknown'),\n  'CLASSIFICATION: ' + (r.meetingType || 'unknown'),\n  'CLIENT FACING: ' + (r.clientFacing ? 'Yes' : 'No'),\n  'NEEDS VERIFICATION: ' + (r.needsVerification ? 'Yes' : 'No'),\n  'CALENDAR EVENT ID: ' + (r.calendarEventId || 'unknown'),\n  'TRACKER ID: ' + (r.resolvedTrackerId || 'none'),\n  'TRACKER ACTION: ' + (r.trackerAction || 'none'),\n  'CONTACT MATCHED: ' + (r.contactMatched ? 'Yes' : 'No'),\n  'ACCOUNT MATCHED: ' + (r.accountMatched ? 'Yes' : 'No'),\n  'NOTES: ' + (r.notes || 'none')\n].join('\\n');\n\nreturn [{ json: { ...r, eventDescription: desc } }];"
      },
