        "query": "=SELECT Id, Name, Onboarding_Meeting_Count__c FROM Client_Onboarding_Tracker__c WHERE Name = '{{ $('Resolve Contact and Account').item.json.trackerName }}' LIMIT 1"
      },
      "id": "SAMPLE_NODE_ID_009",
      "name": "Search Tracker by Name",
      "type": "n8n-nodes-base.salesforce",
      "typeVersion": 1.1,
      "position": [
        1792,
        192
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "\nconst m      = $('Resolve Contact and Account').item.json;\nconst byAcct = $('Search Tracker by Account').item.json;\nconst byName = $('Search Tracker by Name').item.json;\n\nconst existing = (byAcct?.Id ? byAcct : null) || (byName?.Id ? byName : null) || null;\nconst trackerId           = existing?.Id   || null;\nconst trackerName         = existing?.Name || m.trackerName;\nconst currentMeetingCount = Number(existing?.Onboarding_Meeting_Count__c || 0);\nconst newMeetingCount     = currentMeetingCount + 1;\n\nreturn [{ json: { ...m, trackerId, trackerName, trackerExists: !!trackerId, newMeetingCount } }];\n"
      },
      "id": "SAMPLE_NODE_ID_010",
      "name": "Resolve Tracker",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2016,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst m = $input.first().json;\nconst payload = {\n  Onboarding_Source__c:             'Example User Calendar',\n  Onboarding_Status__c:             m.status,\n  Last_Onboarding_Meeting_Date__c:  m.startDateOnly,\n  Next_Onboarding_Meeting_Date__c:  null,\n  Onboarding_Meeting_Count__c:      m.newMeetingCount,\n  Onboarding_Needs_Verification__c: m.needsVerification,\n  Onboarding_Notes__c:              m.notes,\n  Calendar_Event_ID__c:             m.calendarEventId\n};\nif (m.accountId)    payload.OB_Account__c                 = m.accountId;\nif (m.contactId)    payload.Primary_Onboarding_Contact__c = m.contactId;\nif (m.primaryEmail) payload.Primary_Onboarding_Email__c   = m.primaryEmail;\n\nreturn [{ json: { ...m, payload } }];\n"
      },
