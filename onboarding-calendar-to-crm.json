{
  "name": "Onboarding Calendar to CRM",
  "nodes": [
    {
      "parameters": {},
      "id": "SAMPLE_NODE_ID_001",
      "name": "Run Onboarding Sync",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        0,
        144
      ]
    },
    {
      "parameters": {
        "resource": "event",
        "includeRecurringInstances": true,
        "startDateTime": "2025-01-01T00:00:00",
        "endDateTime": "2025-12-31T23:59:59",
        "returnAll": true,
        "output": "fields",
        "fields": [
          "subject",
          "start",
          "end",
          "organizer",
          "attendees",
          "bodyPreview",
          "iCalUId",
          "webLink",
          "isCancelled"
        ]
      },
      "id": "SAMPLE_NODE_ID_002",
      "name": "Fetch Example User Calendar",
      "type": "n8n-nodes-base.microsoftOutlook",
      "typeVersion": 2,
      "position": [
        224,
        144
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst KEYWORDS = ['onboarding','onboarding call','onboarding follow-up','weekly onboarding','follow-up call'];\nconst INTERNAL = 'example.com';\nconst KNOWN = {\n  'client-a.example.com':           { company:'Example Client A',              fallbackEmail:'contact@client.example.com',         isVendor:false },\n  'client-a-alt.example.com':         { company:'Example Client A',              fallbackEmail:'contact@client.example.com',         isVendor:false },\n  'client-b.example.com': { company:'Example Client B', fallbackEmail:'contact@client.example.com', isVendor:false },\n  'client-c.example.com':              { company:'Example Client C',                    fallbackEmail:'contact@client.example.com',             isVendor:false },\n  'client-c-alt.example.com':         { company:'Example Client C',                    fallbackEmail:'contact@client.example.com',             isVendor:false },\n  'vendor-a.example.com':          { company:'Example Vendor A',                 fallbackEmail:'vendor@example.com',            isVendor:true },\n  'vendor-b.example.com':              { company:'Example Vendor B',                     fallbackEmail:'vendor@example.com',               isVendor:true }\n};\n\nconst results = [];\nfor (const item of $input.all()) {\n  const evt = item.json;\n  if (evt.isCancelled) continue;\n\n  const combined = ((evt.subject||'') + ' ' + (evt.bodyPreview||'')).toLowerCase();\n  if (!KEYWORDS.some(k => combined.includes(k))) continue;\n\n  const allAttendees = (evt.attendees||[]).map(a=>a.emailAddress?.address||'').filter(Boolean);\n  const externalAttendees = allAttendees.filter(e=>!e.toLowerCase().endsWith('@'+INTERNAL));\n\n  // Require at least one external attendee — drops internal-only huddles\n  if (externalAttendees.length === 0) continue;\n\n  const startRaw = evt.start?.dateTime || '';\n  const endRaw   = evt.end?.dateTime   || '';\n  const startISO = startRaw.endsWith('Z') ? startRaw : startRaw + 'Z';\n  const endISO   = endRaw.endsWith('Z')   ? endRaw   : endRaw   + 'Z';\n  const calendarEventId = (evt.iCalUId || evt.id || 'unknown') + '_' + startISO.replace(/[^0-9TZ]/g,'');\n  const organizer = evt.organizer?.emailAddress?.address || '';\n  const primaryEmail = externalAttendees[0];\n  const primaryDomain = primaryEmail ? primaryEmail.split('@')[1] : null;\n  const mapped = KNOWN[primaryDomain] || null;\n  const isVendor = mapped?.isVendor || false;\n  const fallbackCompany = mapped?.company || primaryDomain || 'Unknown';\n  const fallbackEmail = mapped?.fallbackEmail || primaryEmail;\n  const externalEmailList = externalAttendees.map(e=>\"'\"+e.replace(/'/g,\"\\\\'\"  )+\"'\").join(',');\n\n  results.push({ json: {\n    calendarEventId,\n    subject:           evt.subject || '',\n    startDateTime:     startISO,\n    endDateTime:       endISO,\n    startDateOnly:     startISO.substring(0,10),\n    organizer,\n    allAttendees:      allAttendees.join(','),\n    externalAttendees: externalAttendees.join(','),\n    externalEmailList,\n    primaryEmail:      fallbackEmail,\n    primaryDomain:     primaryDomain || '',\n    fallbackCompany,\n    isVendor,\n    trackerName:       fallbackCompany + ' - Client Onboarding',\n    meetingType:       isVendor ? 'Vendor Onboarding' : 'Client Onboarding',\n    clientFacing:      !isVendor\n  }});\n}\nreturn results;\n"
      },
      "id": "SAMPLE_NODE_ID_003",
      "name": "Filter and Normalize",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        144
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst items = $input.all();\nlet trackersCreated = 0, trackersUpdated = 0, eventsCreated = 0, eventsSkipped = 0;\nconst errors = [];\nfor (const item of items) {\n  const d = item.json;\n  if (d.trackerAction === 'created') trackersCreated++;\n  if (d.trackerAction === 'updated') trackersUpdated++;\n  if (d.result === 'created' && d.eventCreated) eventsCreated++;\n  if (d.result === 'skipped_duplicate') eventsSkipped++;\n  if (d.sfSuccess === false || d.result === 'error') {\n    errors.push({ calendarEventId: d.calendarEventId, sfRaw: d.sfRawResponse || 'no detail' });\n  }\n}\nreturn [{ json: {\n  status: errors.length === 0 ? 'SUCCESS' : 'COMPLETED_WITH_ERRORS',\n  totalProcessed: items.length,\n  trackersCreated,\n  trackersUpdated,\n  eventsCreated,\n  eventsSkipped,\n  errors,\n  completedAt: new Date().toISOString()\n}}];\n"
      },
      "id": "SAMPLE_NODE_ID_004",
      "name": "Sync Complete",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        896,
        0
      ]
    },
    {
      "parameters": {
        "resource": "search",
        "query": "=SELECT Id, Email, AccountId FROM Contact WHERE Email IN ({{ $('Loop Each Meeting').item.json.externalEmailList }}) LIMIT 1"
      },
      "id": "SAMPLE_NODE_ID_005",
      "name": "Search Contact",
      "type": "n8n-nodes-base.salesforce",
      "typeVersion": 1.1,
      "position": [
        896,
        192
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "resource": "search",
        "query": "=SELECT Id, Name FROM Account WHERE Website LIKE '%{{ $('Loop Each Meeting').item.json.primaryDomain }}%' LIMIT 1"
      },
      "id": "SAMPLE_NODE_ID_006",
      "name": "Search Account by Domain",
      "type": "n8n-nodes-base.salesforce",
      "typeVersion": 1.1,
      "position": [
        1120,
        192
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "\nconst evt         = $('Loop Each Meeting').item.json;\nconst contactItem = $('Search Contact').item.json;\nconst accountItem = $('Search Account by Domain').item.json;\n\nconst contactId    = contactItem?.Id    || null;\nconst contactEmail = contactItem?.Email || null;\nconst accountFromContact = contactItem?.AccountId || null;\nconst accountFromSearch  = accountItem?.Id        || null;\nconst accountId = accountFromContact || accountFromSearch || null;\n\nconst needsVerification = !contactId || !accountId;\n\nconst notes = [\n  'External attendees: ' + (evt.externalAttendees || 'none'),\n  'Primary domain: ' + (evt.primaryDomain || 'unknown'),\n  contactId ? 'Contact: ' + contactId + ' (' + (contactEmail||'') + ')' : 'No Contact match',\n  accountId ? 'Account: ' + accountId + (accountFromContact ? ' (via Contact.AccountId)' : ' (domain fallback)') : 'No Account match',\n  evt.isVendor ? 'VENDOR - needs verification' : ''\n].filter(Boolean).join(' | ');\n\nreturn [{ json: {\n  ...evt,\n  contactId,\n  contactEmail,\n  accountId,\n  whoId:            contactId  || null,\n  whatId:           accountId  || null,\n  primaryEmail:     contactEmail || evt.primaryEmail,\n  needsVerification,\n  notes,\n  status:           needsVerification ? 'Needs Verification' : 'In Progress',\n  contactMatched:   !!contactId,\n  accountMatched:   !!accountId\n}}];\n"
      },
      "id": "SAMPLE_NODE_ID_007",
      "name": "Resolve Contact and Account",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        192
      ]
    },
    {
      "parameters": {
